# kkskills-mcp — environment overrides.
#
# Copy to `.env` and adjust as needed:
#   cp .env.example .env
#
# Loaded by docker-compose.yml (env_file). Inside the running server, CLI
# flags still win over these env vars — so e.g. running the binary with
# `--stdio` will override KKSKILLS_TRANSPORT=http here.
#
# Notes:
#   - .env is git-ignored. .env.example IS tracked — keep it in sync when
#     you add a new variable.
#   - Don't put secrets in here yet — the server has none. If you ever add
#     auth (e.g. a bearer token for the remote HTTP connector), put the
#     placeholder here and the real value only in .env.

# ─── Transport ───────────────────────────────────────────────────────────────
# stdio | http
KKSKILLS_TRANSPORT=http

# ─── HTTP bind ───────────────────────────────────────────────────────────────
# 0.0.0.0 exposes the container externally. Use 127.0.0.1 if you only want
# the host loopback (and you'll need network_mode: host in compose then).
KKSKILLS_HOST=0.0.0.0

# Host-side port that maps to the container's 3030. Change this if 3030
# is taken on the host machine.
KKSKILLS_PORT=3030

# ─── Skills root (path INSIDE the container) ─────────────────────────────────
# Override only if you mount the skills directory at a non-default path.
# Default in the Dockerfile is /app/skills.
# KKSKILLS_ROOT=/app/skills
