{
  "name": "kkskills-mcp",
  "version": "1.0.1",
  "description": "MCP server that exposes a personal Claude skill library as discoverable tools (stdio + Streamable HTTP)",
  "type": "module",
  "bin": {
    "kkskills-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format:check": "prettier --check src",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
