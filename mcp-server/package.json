{
  "name": "kkskills-mcp",
  "version": "0.2.0",
  "description": "MCP server that exposes a personal Claude skill library as discoverable tools (stdio + Streamable HTTP)",
  "type": "module",
  "bin": {
    "kkskills-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
